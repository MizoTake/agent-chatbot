# Slack Bot設定（オプション - 空欄にするとSlackを無効化）
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_APP_TOKEN=xapp-your-app-token

# Discord Bot設定（オプション - 空欄にするとDiscordを無効化）
DISCORD_BOT_TOKEN=your-discord-bot-token

# サーバー設定
PORT=3000

# ログ設定
LOG_LEVEL=info        # debug, info, warn, error
LOG_FORMAT=human      # human または json

# デバッグモード
DEBUG=false

# Claude CLI設定（オプション）
# CLAUDE_COMMAND=claude
# CLAUDE_MAX_OUTPUT_SIZE=10485760 # 10MB（バイト）

# Codex CLI設定（オプション）
# CODEX_COMMAND=codex                        # codex のコマンド名（デフォルト: codex）
# CODEX_API_KEY=your-codex-api-key           # Codex CLIをAPIキー運用する場合のみ設定
# CODEX_PROVIDER=lmstudio                    # プロバイダー（デフォルト: lmstudio）ollama, openai-compatible 等も可
# CODEX_MODEL=                               # モデル名（未指定時は LMStudio 稼働中モデルを自動検出）

# opencode CLI設定（オプション）
# OPENCODE_COMMAND=opencode                # opencode-cli のコマンド名（デフォルト: opencode）
# OPENCODE_ARGS=run {prompt}              # opencode へ渡す引数テンプレート（{prompt} がプロンプトに置換される）
#
# LMStudio連携（scripts/opencode-monitor.sh 経由で起動する場合）
# OPENCODE_USE_MONITOR=true               # true にするとモニタースクリプト経由でopencode-cliを実行
# LMSTUDIO_URL=http://localhost:1234      # LMStudio APIのURL（デフォルト: http://localhost:1234）
# OPENCODE_CHECK_INTERVAL=30             # LMStudio死活確認の間隔（秒、デフォルト: 30）
# OPENCODE_FAIL_THRESHOLD=3              # 連続失敗でopencode-cliをkillするまでの回数（デフォルト: 3）

# TAKT CLI設定（オプション）
# TAKT_COMMAND=takt                        # takt のコマンド名（デフォルト: takt）
# TAKT_ARGS=--pipeline --task {prompt}     # takt へ渡す引数テンプレート（{prompt} がプロンプトに置換される）
# TAKT_ANTHROPIC_API_KEY=your-key          # takt が使う Anthropic APIキー
# TAKT_OPENAI_API_KEY=your-key             # takt が使う OpenAI APIキー

# orcha CLI設定（オプション）
# ORCHA_COMMAND=orcha                      # orcha のコマンド名（デフォルト: orcha）
# .orcha/ ディレクトリはプロジェクトルートのものを対象リポジトリにコピーして使用

# vibe-local連携設定（オプション）
# 既定ツールを切り替える場合のみ設定
# AGENT_CHATBOT_TOOLS_DEFAULTTOOL=claude # 例: opencode / codex / vibe-local
# AGENT_CHATBOT_APP_NAME=opencode        # Slack/Discordの表示名を固定する場合
# OLLAMA_HOST=http://localhost:11434
# VIBE_LOCAL_MODEL=qwen3:8b
# VIBE_LOCAL_SIDECAR_MODEL=qwen3:1.7b
# VIBE_LOCAL_DEBUG=1
# 必要に応じて（vibe-coder 側の上書き）
# VIBE_CODER_MODEL=qwen3:8b
# VIBE_CODER_SIDECAR=qwen3:1.7b
# VIBE_CODER_DEBUG=1
