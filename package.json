{
  "name": "agent-chatbot",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "nodemon --exec ts-node src/index.ts",
    "build": "npm run clean && node ./node_modules/typescript/bin/tsc",
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "typecheck": "node ./node_modules/typescript/bin/tsc --noEmit",
    "check": "npm run typecheck && npm test",
    "test": "npm run build && node --test \"dist/**/*.test.js\""
  },
  "keywords": [
    "claude",
    "discord",
    "bot",
    "ai",
    "assistant"
  ],
  "author": "",
  "license": "MIT",
  "description": "Discord bot that integrates agent CLIs (Claude/Codex/vibe-local) with Git repository context awareness",
  "dependencies": {
    "axios": "^1.9.0",
    "discord.js": "^14.16.3",
    "dotenv": "^16.5.0",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.15.29",
    "nodemon": "^3.1.10",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}
